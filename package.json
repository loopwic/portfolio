{
  "name": "portfolio",
  "version": "1.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "WRANGLER_LOG_PATH=.wrangler/logs vite build",
    "start": "vite preview",
    "lint": "biome check",
    "format": "biome format --write",
    "prepare": "lefthook install",
    "release": "semantic-release",
    "deploy": "bun run build && wrangler deploy",
    "preview": "bun run build && wrangler dev",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.168.26",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "^1.167.52",
    "@tanstack/router-plugin": "^1.167.29",
    "@types/mdx": "^2.0.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^0.543.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-toc": "^9.0.0",
    "shiki": "^3.23.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@cloudflare/vite-plugin": "^1.34.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.2.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "lefthook": "^1.13.6",
    "lint-staged": "^16.4.0",
    "sass-embedded": "^1.99.0",
    "semantic-release": "^24.2.9",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "5.3.3",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.86.0"
  },
  "packageManager": "bun@1.3.13",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,mdx}": [
      "bun run format"
